# Database
# Supabase — для приложения (FastAPI) используйте Transaction pooler :6543, не direct :5432.
# Dashboard → Project Settings → Database → Connection string → «Transaction pooler».
# Пример (регион и PROJECT_REF подставьте из Dashboard):
#   postgresql://postgres.[PROJECT_REF]:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct :5432 — для psql/миграций; через pooler меньше latency на новое TCP + SSL.
DATABASE_URL=postgresql://postgres:password@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Пул SQLAlchemy (под нагрузку увеличьте; для PgBouncer обычно 5–10 достаточно)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=280
# PG_SSLMODE=require

# Логировать разбивку времени в POST /api/requests (user, commit, …)
# DEBUG_DB_TIMING=1

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# AI Chat Bot
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here

# Data.egov.kz API (для верификации компаний)
EGOV_API_KEY=your_egov_api_key_here

